rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Public profile lookup and settings used by the app.
    // Anyone can read public pages, but only the owner can write their user doc.
    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);

      // Public profile document used by /mypage and the public header.
      match /profile/{profileId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }

      // Public link list rendered on /[displayname].
      match /links/{linkId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }

      // Public social links shown on the profile dock/header stats.
      match /socials/{socialId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    // Username reservation index.
    // Reads are public so the app can check availability.
    // Writes are restricted so a user can only reserve/update/delete usernames
    // that point to their own auth uid.
    match /usernames/{username} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;

      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;

      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Everything else is private by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
